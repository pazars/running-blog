# build output
dist/
# generated types
.astro/
# Cloudflare binding types from `wrangler types` (npm run cf-typegen).
# Regenerate after changing bindings in wrangler.toml; not committed.
worker-configuration.d.ts

# dependencies
node_modules/

# Non-npm lockfiles. npm is the canonical package manager (CI runs `npm ci`;
# package-lock.json is the committed lockfile). Keep other managers' lockfiles
# out of the repo so they can't drift out of sync with package-lock.json.
bun.lock
bun.lockb
yarn.lock
pnpm-lock.yaml

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
# Cloudflare local secrets/vars (used by `wrangler pages dev`). The
# database_id in wrangler.toml is a non-secret identifier and is committed;
# real secrets/tokens live here and must never be committed.
.dev.vars
.dev.vars.*
# ...except the committed template (placeholders only, no real secrets).
!.dev.vars.example

# Cloudflare local dev state (local D1 SQLite + cache) from `wrangler pages dev`
.wrangler/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# docs
docs/
