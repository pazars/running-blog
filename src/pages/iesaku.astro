---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import RecommendationCard from "../components/RecommendationCard.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";
import { getCollection } from "astro:content";
import { fetchOgImage } from "../utils/ogImage";

// Recommendations sorted by title (there's no date to sort by). Each card
// carries its tags + language in data-* attributes so the scoped script below
// can filter entirely on the client (mirrors the blog list; the dropdown
// filters by language instead of sorting).
const items = (await getCollection("recommendations", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.title.localeCompare(b.data.title, "lv"),
);

const allTags = [...new Set(items.flatMap((p) => p.data.tags))].sort((a, b) =>
  a.localeCompare(b, "lv"),
);

// Latvian labels for the language dropdown; only languages actually present in
// the content get an option (plus the "all" default).
const LANGUAGE_LABELS: Record<string, string> = {
  lv: "Latviski",
  en: "Angliski",
};
const languages = (["lv", "en"] as const).filter((code) =>
  items.some((p) => p.data.language === code),
);

// Display label only — the raw tag stays in `data-tag` for matching/deep-links.
const capitalize = (s: string) =>
  s.charAt(0).toLocaleUpperCase("lv") + s.slice(1);

// 1110x773 placeholder matching the site's image style, used when no thumbnail
// is set and the build-time og:image fetch comes up empty.
const PLACEHOLDER = "https://placehold.co/1110x773/e8eaf0/555560?text=Iesaku";

// Resolve each thumbnail at build time: an explicit override wins, otherwise
// fetch the primary link's og:image (falling back to the placeholder).
const thumbnails = await Promise.all(
  items.map((item) =>
    item.data.thumbnail
      ? Promise.resolve(item.data.thumbnail)
      : fetchOgImage(item.data.links[0].url, PLACEHOLDER),
  ),
);
---

<BaseLayout
  description="Dāvja Pazara ieteikumi — podkāsti un YouTube kanāli par skriešanu, treniņiem un zinātni aiz tiem."
>
  <Header
    name={site.name}
    role={site.role}
    activePage="iesaku"
  />

  <main>
    <section class="section-hero -no-eyebrow">
      <p>
        Cilvēki un saturs, kas mani iedvesmo. Tiks papildināts.
      </p>
    </section>

    <section class="rec-section">
      <!-- Filters: category chips (multi-select, OR) + a language dropdown. -->
      <div class="blog-filters" data-js-rec-filters>
        <div
          class="blog-chips"
          data-js-tag-filter
          aria-label="Filtrēt pēc kategorijas"
        >
          <button
            type="button"
            class="btn btn-secondary blog-chip active"
            data-tag=""
            aria-pressed="true"
          >
            Visi
          </button>
          {
            allTags.map((tag) => (
              <button
                type="button"
                class="btn btn-invisible blog-chip"
                data-tag={tag}
                aria-pressed="false"
              >
                {capitalize(tag)}
              </button>
            ))
          }
        </div>

        {
          languages.length > 0 && (
            <div class="blog-selects">
              <label class="blog-select-label">
                <span class="sr-only">Valoda</span>
                <select class="blog-select" data-js-lang>
                  <option value="">Visas valodas</option>
                  {languages.map((code) => (
                    <option value={code}>{LANGUAGE_LABELS[code]}</option>
                  ))}
                </select>
              </label>
            </div>
          )
        }
      </div>

      <!-- Recommendation cards -->
      <div class="blog-list" data-js-rec-list>
        {
          items.map((item, i) => (
            <div
              class="blog-list-item"
              data-tags={item.data.tags.join(",")}
              data-lang={item.data.language}
            >
              <RecommendationCard
                href={item.data.links[0].url}
                title={item.data.title}
                summary={item.data.description}
                imageUrl={thumbnails[i]}
                imageAlt={item.data.thumbnailAlt ?? item.data.title}
                links={item.data.links}
              />
            </div>
          ))
        }
      </div>

      <p class="blog-empty color-fg-muted d-none" data-js-rec-empty>
        Nav atrasts neviens ieteikums ar šo filtru.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Match the Sasniegumi page's vertical rhythm: the intro sits in its own hero
     section, and the content lives in a second section whose 28px top padding
     puts the filter row the same distance below the intro as Sasniegumi's first
     section sits below its intro. */
  .rec-section {
    padding-top: 28px;
  }
  /* Let the content sit flush so only the footer's own margin spaces it
     (mirrors the blog listing and Sasniegumi). */
  main > section:last-child {
    padding-bottom: 0;
  }
  /* The hero's first paragraph carries the default 16px top margin, which would
     push it lower than the blog's (margin-less) filter row sits. Drop it so the
     header-to-content distance matches the blog listing (and Sasniegumi). */
  section.section-hero > p:first-child {
    margin-top: 0;
  }
</style>

<script>
  // Client-side filtering for the recommendation list. All data lives in the
  // cards' data-* attributes, so this is pure DOM work — no fetch, no framework
  // (matching the project's vanilla-JS convention; scoped to this page). Tag
  // chips (OR gate) and the language dropdown combine with AND.
  (function () {
    const list = document.querySelector<HTMLElement>("[data-js-rec-list]");
    const tagBar = document.querySelector<HTMLElement>("[data-js-tag-filter]");
    const langSel = document.querySelector<HTMLSelectElement>("[data-js-lang]");
    const empty = document.querySelector<HTMLElement>("[data-js-rec-empty]");
    if (!list) return;

    const items = Array.from(
      list.querySelectorAll<HTMLElement>(".blog-list-item"),
    );
    // Cumulative tag filter: an empty set means "Visi" (show all); otherwise a
    // card shows if it carries *any* selected tag (OR gate).
    const activeTags = new Set<string>();

    function apply() {
      const lang = langSel?.value || "";
      let visible = 0;
      items.forEach((el) => {
        const tags = (el.dataset.tags || "").split(",").filter(Boolean);
        const tagShow =
          activeTags.size === 0 ||
          [...activeTags].some((t) => tags.includes(t));
        const langShow = !lang || el.dataset.lang === lang;
        const show = tagShow && langShow;
        el.classList.toggle("d-none", !show);
        if (show) visible++;
      });
      empty?.classList.toggle("d-none", visible !== 0);
    }

    // Reflect the active set onto the chips. The "Visi" chip (empty data-tag)
    // lights up only when no specific tags are selected.
    function syncTagButtons() {
      tagBar?.querySelectorAll<HTMLElement>("[data-tag]").forEach((btn) => {
        const tag = btn.dataset.tag || "";
        const on = tag ? activeTags.has(tag) : activeTags.size === 0;
        btn.classList.toggle("active", on);
        btn.classList.toggle("btn-secondary", on);
        btn.classList.toggle("btn-invisible", !on);
        btn.setAttribute("aria-pressed", String(on));
      });
    }

    tagBar?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-tag]");
      if (!btn) return;
      const tag = btn.dataset.tag || "";
      // "Visi" clears everything; a specific tag toggles in/out.
      if (!tag) {
        activeTags.clear();
      } else if (activeTags.has(tag)) {
        activeTags.delete(tag);
      } else {
        activeTags.add(tag);
      }
      syncTagButtons();
      apply();
    });

    langSel?.addEventListener("change", apply);

    // Allow deep-linking, e.g. /iesaku?tag=youtube&lang=lv
    const params = new URLSearchParams(window.location.search);
    const urlTag = params.get("tag");
    if (
      urlTag &&
      items.some((el) =>
        (el.dataset.tags || "").split(",").includes(urlTag),
      )
    ) {
      activeTags.add(urlTag);
    }
    const urlLang = params.get("lang");
    if (langSel && urlLang && items.some((el) => el.dataset.lang === urlLang)) {
      langSel.value = urlLang;
    }

    syncTagButtons();
    apply();
  })();
</script>
