---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { site, newsletterPages } from "../../site.config";

const page = newsletterPages.unsubscribe;
---

<BaseLayout
  title={page.title}
  description="Turpmāk vairs nesaņemsi e-pastus."
>
  <Header
    name={site.name}
    role={site.role}
    company={site.company}
    email={site.email}
    activePage="none"
  />

  <main>
    <section class="section-hero -no-eyebrow">
      <h1>{page.title}</h1>
      <p>{page.body}</p>
      <p><a href={page.linkHref}>{page.linkText}</a></p>
    </section>
  </main>

  <Footer email={site.email} />
</BaseLayout>
