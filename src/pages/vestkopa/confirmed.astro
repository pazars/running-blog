---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { site, newsletterPages } from "../../site.config";

const page = newsletterPages.confirmed;
---

<BaseLayout
  title={page.title}
  description="Tava pierakstīšanās Dāvja Pazara vēstkopai ir apstiprināta."
>
  <Header
    name={site.name}
    role={site.role}
    company={site.company}
    email={site.email}
    activePage="none"
  />

  <main>
    <section class="section-hero -no-eyebrow">
      <h1>{page.title}</h1>
      <p>{page.body}</p>
      <p><a href={page.linkHref}>{page.linkText}</a></p>
    </section>
  </main>

  <Footer email={site.email} />
</BaseLayout>

<script is:inline>
  // Reaching this page means the visitor clicked the confirm link — record the
  // genuine "confirmed" state so the sign-up forms/popup show the real "subscribed"
  // panel and stop prompting, and clear the interim "pending" flag. Keys must match
  // those in public/script.js (newsletter-confirmed / newsletter-pending).
  try {
    localStorage.setItem("newsletter-confirmed", "true");
    localStorage.removeItem("newsletter-pending");
  } catch {}
</script>
