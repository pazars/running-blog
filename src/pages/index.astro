---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
---

<BaseLayout title="Dāvis Pazars — drīzumā">
  <main class="coming-soon">
    <!-- Kalnu grēda — krāsas no dizaina tokeniem,
         tāpēc grafika pielāgojas arī tumšajam režīmam. -->
    <svg
      class="graphic color-fg-muted"
      width="280"
      height="120"
      viewBox="0 0 280 120"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M8 104 H272"
        stroke="var(--color-line-default)"
        stroke-width="1.5"
        stroke-linecap="round"
      />
      <path
        d="M8 104 L64 44 L96 78 L140 24 L196 88 L232 56 L272 104"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>

    <h1>Drīzumā</h1>

    <p class="color-fg-muted">Pa to laiku mani vari atrast šeit:</p>

    <nav class="socials d-flex flex-items-center gap-5" aria-label="Sociālie tīkli">
      {
        site.socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener"
            class="d-flex flex-items-center gap-1"
          >
            {social.label}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="trailingIcon"
            >
              <path d="M7 7h10v10" />
              <path d="M7 17 17 7" />
            </svg>
          </a>
        ))
      }
    </nav>
  </main>
</BaseLayout>

<style>
  /* Fill the viewport minus the actual body padding (it grows past the
     --body-padding token at the breakpoints below) so the group centers. */
  .coming-soon {
    min-height: calc(100svh - 2 * var(--body-padding));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .coming-soon {
      min-height: calc(100svh - 2 * 60px);
    }
  }

  @media (min-width: 1012px) {
    .coming-soon {
      min-height: calc(100svh - 2 * 80px);
    }
  }

  .graphic {
    max-width: 100%;
    height: auto;
    margin-bottom: 16px;
  }

  .coming-soon h1 {
    margin: 0;
  }

  .socials {
    margin-top: 8px;
  }

  .socials a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }

  .socials a:hover {
    color: var(--color-fg-default);
    text-decoration: underline;
    text-decoration-color: var(--color-line-emphasis);
  }
</style>
