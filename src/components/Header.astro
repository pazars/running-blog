---
import { site, navLinks, newsletter } from "../site.config";
import { gravatarUrl } from "../utils/avatar";

// Site-wide profile image from the Gravatar account (see src/utils/avatar.ts).
const gravatarAvatar = gravatarUrl(160);
// Larger render shown when the avatar is hovered (desktop) or tapped (mobile).
const gravatarAvatarLarge = gravatarUrl(480);

interface Props {
  name: string;
  role: string;
  company: string;
  email: string;
  avatarUrl?: string;
  activePage?: string;
}

const {
  name,
  role,
  company,
  email,
  avatarUrl = gravatarAvatar,
  activePage = "blog",
} = Astro.props;
---

<header class="mb-4">
  <div class="brand d-flex flex-items-center">
    <div class="wrapper d-flex flex-items-center" data-js-avatar-zoom>
      <button
        type="button"
        class="image-container mr-3"
        aria-label="Enlarge profile picture"
        data-js-avatar-trigger
      >
        <img
          src={avatarUrl}
          alt="Profile headshot"
          class="image"
          width="80"
          height="80"
        />
      </button>
      <a href="/" class="info">
        <div class="title">{name}</div>
        <div class="desc color-fg-muted">{role}</div>
      </a>
      <div class="avatar-zoom-preview" data-js-avatar-preview>
        <img
          src={gravatarAvatarLarge}
          alt="Profile picture, enlarged"
          class="avatar-zoom-img"
          width="240"
          height="240"
        />
      </div>
    </div>
  </div>
  <div class="links d-flex flex-items-center flex-justify-end gap-1">
    <label
      class="toggle-nav d-flex flex-items-center flex-justify-end gap-1"
      data-js-toggle-nav-container
    >
      <input type="checkbox" class="input d-none" data-js-nav-input />
      <button
        aria-label="Toggle nav"
        class="navButton flex-0 btn-icon btn-invisible"
        data-js-nav-button
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="content icon d-flex"
          data-js-menu-collapsed="true"
        >
          <path d="M4 5h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 19h16"></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="content icon d-none"
          data-js-menu-expanded="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
      <div class="menu">
        <nav class="d-flex flex-items-center gap-1">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={`link ${activePage === link.id ? "active" : ""}`}
              >
                <div class="item py-2 px-3">{link.text}</div>
              </a>
            ))
          }
        </nav>
      </div>
    </label>
    <div class="line" data-js-line>
      <div class="divider-line pl-2 mr-2"></div>
    </div>
    <div class="contact" data-js-contact>
      <div class="dropdown-container">
        <div class="trigger tooltip-container" data-js-dropdown-trigger>
          <div class="tooltip-container" data-js-tooltip-container>
            <button class="btn-icon btn-invisible tooltip-button">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="content icon"
              >
                <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              </svg>
            </button>
            <span
              class="tooltip"
              data-position="bottom"
              data-visible="false"
              data-js-tooltip-text>Vēstkopa</span
            >
          </div>
        </div>
        <div class="panel subscribe-panel" data-js-dropdown-panel>
          <div
            class="subscribe-popup"
            data-js-newsletter-form
            data-msg-pending={newsletter.pendingMessage}
            data-msg-hint={newsletter.pendingHint}
            data-msg-already={newsletter.alreadyMessage}
            data-msg-error={newsletter.errorMessage}
            data-msg-ratelimit={newsletter.rateLimitMessage}
          >
            <p class="subscribe-popup-desc">
              Kopsavilkumi par jaunākajiem rakstiem
            </p>
            <form class="subscribe-popup-form d-flex gap-2" data-js-newsletter-submit>
              <input
                type="email"
                name="email"
                placeholder="tavs@epasts.lv"
                required
                autocomplete="email"
                class="newsletter-input flex-1"
                data-js-newsletter-email
              />
              <button
                type="submit"
                class="newsletter-btn btn-secondary"
                data-js-newsletter-btn
                data-label-submitting={newsletter.submittingLabel}
              >
                {newsletter.subscribeButton}
              </button>
              {
                newsletter.turnstileSiteKey && (
                  <div
                    class="cf-turnstile"
                    data-sitekey={newsletter.turnstileSiteKey}
                    data-theme="auto"
                    data-appearance="interaction-only"
                  />
                )
              }
            </form>
            <p class="newsletter-note">{newsletter.unsubscribeNote}</p>
            <div class="newsletter-status" data-js-newsletter-status aria-live="polite"></div>
            <div class="newsletter-toast" data-js-newsletter-toast hidden tabindex="-1">
              <p class="newsletter-toast-text" data-js-toast-text aria-live="polite"></p>
              <p class="newsletter-note" data-js-toast-hint></p>
              <span class="newsletter-toast-bar" data-js-toast-bar aria-hidden="true"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Toggle the enlarged avatar on tap (mobile, where there's no hover).
  // Desktop relies on CSS :hover; the click toggle is harmless there too.
  document
    .querySelectorAll<HTMLElement>("[data-js-avatar-zoom]")
    .forEach((zoom) => {
      const trigger = zoom.querySelector("[data-js-avatar-trigger]");
      trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        zoom.classList.toggle("is-open");
      });
    });

  // Tapping anywhere else closes any open preview.
  document.addEventListener("click", () => {
    document
      .querySelectorAll("[data-js-avatar-zoom].is-open")
      .forEach((zoom) => zoom.classList.remove("is-open"));
  });
</script>

<style>
  /* The avatar acts as a button; strip the native button chrome. */
  .image-container[data-js-avatar-trigger] {
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }

  .avatar-zoom-preview {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    z-index: 1200;
    padding: 6px;
    background: var(--bgColor-default, #ffffff);
    border: 1px solid var(--borderColor-default, #d1d9e0);
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s;
  }

  .avatar-zoom-img {
    display: block;
    width: 200px;
    height: 200px;
    max-width: 60vw;
    border-radius: 10px;
  }

  /* Tap-to-open state (used on touch devices). */
  .wrapper.is-open .avatar-zoom-preview {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Hover-to-open on devices that support hovering. */
  @media (hover: hover) {
    [data-js-avatar-trigger]:hover ~ .avatar-zoom-preview,
    .avatar-zoom-preview:hover {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }
</style>
