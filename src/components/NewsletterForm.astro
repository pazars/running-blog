---
import SectionHeader from "./SectionHeader.astro";
import { newsletter } from "../site.config";

interface Props {
  description?: string;
  showBorder?: boolean;
  hideWhenSubscribed?: boolean;
}

const {
  description = "Saņemsi bloga rakstu kopsavilkums ne biežāk kā reizi dažās nedēļās. Raksti saturēs ikvienam noderīgu informāciju par treniņiem, sacensību atskatiem un to, kā paņemt mācības no sporta pārējai dzīvei.",
  showBorder = false,
  hideWhenSubscribed = false,
} = Astro.props;
---

<section
  class={`newsletter-form-section ${showBorder ? "border-top" : ""}`}
  data-js-newsletter-form
  data-js-hide-when-subscribed={hideWhenSubscribed ? "true" : undefined}
  data-msg-pending={newsletter.pendingMessage}
  data-msg-already={newsletter.alreadyMessage}
  data-msg-error={newsletter.errorMessage}
  data-msg-ratelimit={newsletter.rateLimitMessage}
>
  <p>{description}</p>
  <form class="newsletter-form d-flex gap-2" data-js-newsletter-submit>
    <input
      type="email"
      name="email"
      placeholder="tavs@epasts.lv"
      required
      autocomplete="email"
      class="newsletter-input flex-1"
      data-js-newsletter-email
    />
    <button type="submit" class="newsletter-btn btn-secondary" data-js-newsletter-btn>
      {newsletter.subscribeButton}
    </button>
    {
      newsletter.turnstileSiteKey && (
        <div class="cf-turnstile" data-sitekey={newsletter.turnstileSiteKey} />
      )
    }
  </form>
  <p class="newsletter-note">{newsletter.unsubscribeNote}</p>
  <div class="newsletter-status" data-js-newsletter-status></div>
</section>
